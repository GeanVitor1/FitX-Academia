{
  "buildCommand": "ng build",
  "outputDirectory": "dist/fitx-web/browser",
  "rewrites": [
    { "source": "/(.*\\.(js|css|json|ico|png|jpg|jpeg|svg|webp|woff2?|ttf|eot))", "destination": "/$1" },
    { "source": "/(assets/.*)", "destination": "/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
